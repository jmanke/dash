{
  "name": "hellodash-components",
  "version": "0.0.1",
  "description": "Stencil Component Starter",
  "main": "dist/index.cjs.js",
  "module": "dist/index.js",
  "es2015": "dist/esm/index.mjs",
  "es2017": "dist/esm/index.mjs",
  "types": "dist/types/index.d.ts",
  "collection": "dist/collection/collection-manifest.json",
  "collection:main": "dist/collection/index.js",
  "unpkg": "dist/hellodash-components/hellodash-components.esm.js",
  "repository": {
    "type": "git",
    "url": "https://github.com/ionic-team/stencil-component-starter.git"
  },
  "files": [
    "dist/",
    "loader/"
  ],
  "scripts": {
    "build": "stencil build --docs",
    "start": "stencil build --dev --watch --serve",
    "test": "stencil test --spec --e2e",
    "test.watch": "stencil test --spec --e2e --watchAll",
    "generate": "stencil generate"
  },
  "dependencies": {
    "@didyoumeantoast/dash-components": "^1.1.1",
    "@didyoumeantoast/dash-utils": "^1.1.3",
    "@stencil/core": "^2.15.0"
  },
  "devDependencies": {
    "@auth0/auth0-spa-js": "^1.19.4",
    "@stencil/postcss": "^2.1.0",
    "@types/jest": "^27.0.3",
    "autoprefixer": "^10.4.13",
    "jest": "^27.4.5",
    "jest-cli": "^27.4.5",
    "postcss": "link:@types/@stencil/postcss",
    "postcss-extend-rule": "^4.0.0",
    "postcss-nested": "^5.0.6",
    "postcss-replace": "^2.0.0",
    "puppeteer": "^10.0.0",
    "rollup": "1.20.0",
    "rollup-plugin-dotenv": "^0.3.0"
  },
  "peerDependencies": {
    "@auth0/auth0-spa-js": "^1.19.4"
  },
  "license": "MIT"
}
